{
  "name": "claude-session-manager",
  "version": "0.2.0",
  "description": "Desktop app for managing multiple Claude Code terminal sessions with grid view, bulk resume, and AI-powered session naming",
  "author": "samko@samlab.co.kr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ree9622/claude-session-manager"
  },
  "keywords": [
    "claude",
    "claude-code",
    "terminal",
    "session-manager",
    "electron"
  ],
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "appId": "com.samlab.claude-session-manager",
    "productName": "Claude Session Manager",
    "copyright": "Copyright © 2026 samlab.co.kr",
    "files": [
      "dist/**/*",
      "!dist/win-unpacked",
      "!dist/builder-*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      { "from": "build/icon.png", "to": "icon.png" },
      { "from": "build/tray-icon.png", "to": "tray-icon.png" }
    ],
    "publish": {
      "provider": "github",
      "owner": "ree9622",
      "repo": "claude-session-manager"
    }
  }
}
